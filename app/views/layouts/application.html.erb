<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "DebugMe — 悩みをデバッグログに変換" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="あなたの悩みをAIがデバッグログに変換。深刻度・原因・解決策を診断します。">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
