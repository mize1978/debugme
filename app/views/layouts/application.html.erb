<!DOCTYPE html>
<html lang="ja">
  <head>
    <% page_title = content_for(:title) || "DebugMe — 悩みをデバッグログに変換" %>
    <% page_desc  = "悩みをデバッグログに変換するAIツール。ラバーダックデバッグで、言語化するだけで気持ちが整理される。" %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= page_desc %>">
    <link rel="icon" type="image/svg+xml" href="/images/debug-cat.svg">

    <!-- Open Graph / Twitter Card -->
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="DebugMe">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_desc %>">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= request.base_url %>/images/ogp.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="675">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_desc %>">
    <meta name="twitter:image" content="<%= request.base_url %>/images/ogp.png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&family=JetBrains+Mono:wght@400;700;900&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
